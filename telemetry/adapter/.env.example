# tesboard telemetry adapter — copy to .env and fill in. .env is gitignored.

# Supabase SESSION pooler connection (:5432), NOT Hyperdrive, NOT the :6543 transaction pooler.
# The adapter writes snapshots/sessions directly to Postgres over outbound TLS.
DIRECT_URL=

# Local MQTT broker on the internal compose network (no host port).
MQTT_URL=tcp://mosquitto:1883

# MQTT client id (unique per broker connection).
MQTT_CLIENT_ID=tesboard-telemetry-adapter

# Must match the fleet-telemetry config.json mqtt.topic_base.
TOPIC_BASE=tesla

# Flush coalesced snapshots every N seconds while a car is active (driving/charging).
FLUSH_INTERVAL_ACTIVE_S=20

# Flush interval while a car is idle.
FLUSH_INTERVAL_IDLE_S=60

# NOTE: liveness silence threshold (LIVENESS_SILENCE_MIN) is a CLOUDFLARE WORKER var
# (the hourly cron's backstop check), not an adapter var. The adapter self-reports a
# `telemetry_silent` anomaly immediately when connectivity drops with an open session.
