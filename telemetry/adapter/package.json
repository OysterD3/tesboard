{
  "name": "tesboard-telemetry-adapter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Co-located Node adapter: coalesces Tesla Fleet Telemetry MQTT deltas into full snapshots and reuses the main app's sessionization (src/server/sessionize.ts), writing to Supabase over a direct :5432 session-pooler connection.",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node20 --alias:@core=../../src/server --outfile=dist/index.js --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "mqtt": "^5.10.4",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "esbuild": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.5"
  }
}
